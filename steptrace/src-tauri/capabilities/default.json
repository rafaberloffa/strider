{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "StepTrace default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-is-registered",
    "dialog:allow-save",
    "dialog:allow-open",
    "fs:allow-read-dir",
    "fs:allow-write-file",
    "fs:allow-mkdir",
    "fs:allow-read-file",
    "shell:allow-open",
    "notification:default"
  ]
}
